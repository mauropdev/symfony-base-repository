#!/usr/bin/env bash

set -e

# Get staged PHP files under src/
mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '^src/.*\.php$' || true)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    exit 0
fi

HAS_ERRORS=0

# ── PHP CS Fixer ────────────────────────────────────────────────────────────
if [ -f "tools/php-cs-fixer/vendor/bin/php-cs-fixer" ]; then
    echo "Running PHP CS Fixer..."
    if ! tools/php-cs-fixer/vendor/bin/php-cs-fixer fix \
            --dry-run \
            --diff \
            --show-progress=none \
            "${STAGED_FILES[@]}"; then
        echo ""
        echo "PHP CS Fixer detected issues. Run 'make cs-fix' to fix them automatically."
        HAS_ERRORS=1
    fi
else
    echo "PHP CS Fixer not found. Run 'make cs-install' to install it."
fi

# ── PHPStan ─────────────────────────────────────────────────────────────────
if [ -f "vendor/bin/phpstan" ]; then
    echo "Running PHPStan..."
    if ! vendor/bin/phpstan analyse -c phpstan.dist.neon --no-progress; then
        echo ""
        echo "PHPStan detected issues. Fix them before committing."
        HAS_ERRORS=1
    fi
fi

exit $HAS_ERRORS
